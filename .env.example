# Investigator — environment template.
# Copy to `.env` and fill in your values. The real `.env` is git-ignored.

# Required: OpenAI API key used by the pipeline engine (entity/event
# extraction, edge enrichment) and the UI's query-refinement endpoint.
OPENAI_API_KEY=

# Optional: override the default model. Defaults to gpt-4.1 in the engine.
# LLM_MODEL=openai/gpt-4.1
